  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.41",
    "@types/pino-http": "^5.8.4",
    "pino-pretty": "^11.2.1",
    "prisma": "^5.0.0",
